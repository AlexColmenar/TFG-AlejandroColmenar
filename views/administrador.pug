extends ./fijo/index

block contenido
    include ./fijo/header

    .d-flex(style="min-height: 100vh;")
        aside.p-4.bg-white.border-end.texto(style="width: 250px;")


            .nav.flex-column.nav-pills(role="tablist")(style="position:sticky; top: 150px;")
                h5.fw-bold.mb-4.border-bottom.pb-2 Panel de Gestión

                button.nav-link.active.text-start.mb-2(data-bs-toggle="pill" data-bs-target="#tab-inicio" type="button")
                    i.bi.bi-house-door.me-2
                    | Resumen

                button.nav-link.text-start.mb-2(data-bs-toggle="pill" data-bs-target="#tab-productos" type="button")
                    i.bi.bi-box-seam.me-2
                    | Añadir Producto

                button.nav-link.text-start.mb-2(data-bs-toggle="pill" data-bs-target="#tab-encuentros" type="button")
                    i.bi.bi-calendar-event.me-2
                    | Añadir Encuentro

                button.nav-link.text-start.mb-2(data-bs-toggle="pill" data-bs-target="#tab-lista-productos" type="button")
                    i.bi.bi-list-ul.me-2
                    | Lista Productos

                button.nav-link.text-start.mb-2(data-bs-toggle="pill" data-bs-target="#tab-lista-encuentros" type="button")
                    i.bi.bi-list-ul.me-2
                    | Lista Encuentros

                button.nav-link.text-start.mb-2(data-bs-toggle="pill" data-bs-target="#tab-usuarios" type="button")
                    i.bi.bi-person-circle.me-2
                    | Usuarios y Pedidos

        main.flex-grow-1.bg-light.p-5.texto
            .tab-content

                .tab-pane.fade.show.active#tab-inicio
                    h2 Bienvenido al Panel
                    p Selecciona una opción en el menú de la izquierda para añadir lo que considere oportuno.

                .tab-pane.fade#tab-productos
                    include ./fijo/nuevoProducto

                .tab-pane.fade#tab-encuentros
                    include ./fijo/nuevoEncuentro

                .tab-pane.fade#tab-lista-productos
                    include ./fijo/crudProductos

                .tab-pane.fade#tab-lista-encuentros
                    include ./fijo/crudEncuentros

                .tab-pane.fade#tab-usuarios
                    h2.mb-4 Historial de Clientes
                    .accordion#acordeonPedidos
                        each usuario, index in usuarios
                            .accordion-item.mb-2
                                h2.accordion-header
                                    button.accordion-button.collapsed(type="button" data-bs-toggle="collapse" data-bs-target="#collapsePedidos" + index)
                                        strong #{usuario.nombre} &nbsp; - #{usuario.email}
                                .accordion-collapse.collapse(id="collapsePedidos" + index data-bs-parent="#acordeonPedidos")
                                    .accordion-body
                                        table.table.table-striped
                                            thead
                                                tr
                                                    th Nº Pedido
                                                    th Total
                                                    th Factura
                                                    th Producto
                                            tbody
                                                each pedido in pedidos
                                                    if pedido.usuario.email === usuario.email
                                                        tr
                                                            td #{pedido.id}
                                                            td #{pedido.total} €
                                                            td: a.btn.btn-sm.btn-dark(href="/facturas/Factura-" + pedido.id + ".pdf" target="_blank") Ver PDF
                                                            td: img(src="/img/productos/" + pedido.detalles[0].producto.imagen style="width: 40px; border-radius: 4px;")

                    h2.mt-5.mb-4 Historial de Encuentros
                    .accordion#acordeonEncuentros
                        each usuario, index in usuarios
                            .accordion-item.mb-2
                                h2.accordion-header
                                    button.accordion-button.collapsed(type="button" data-bs-toggle="collapse" data-bs-target="#collapseEncuentros" + index)
                                        strong #{usuario.nombre} &nbsp; - #{usuario.email}

                                .accordion-collapse.collapse(id="collapseEncuentros" + index data-bs-parent="#acordeonEncuentros")
                                    .accordion-body
                                        table.table.table-striped
                                            thead
                                                tr
                                                    th Nº Reserva
                                                    th Ciudad
                                                    th Hora
                                                    th Entrada
                                                    th Encuentro
                                            tbody
                                                each reserva in reservas
                                                    if reserva.usuario.email === usuario.email
                                                        tr
                                                            td #{reserva.id}
                                                            td #{reserva.ciudad}
                                                            td #{moment(reserva.encuentro.tiempo).format('LLL')}
                                                            td: a.btn.btn-sm.btn-dark(href="/entradas/Entrada-" + reserva.id + ".pdf" target="_blank") Ver PDF
                                                            td: img(src="/img/encuentros/" + reserva.encuentro.imagen style="width: 40px; border-radius: 5px")
    include ./fijo/footer