extends ./fijo/index

block contenido
    include ./fijo/header
    main.container.mt-5.texto.p-5
        .row.bg-white.border-0.rounded-4.shadow-lg.overflow-hidden.mb-5

            .col-12.col-lg-6.p-0
                img(src=`/img/encuentros/${encuentro.imagen}`, alt=`${encuentro.nombre}`, class="img-fluid w-100 h-100 object-fit-cover", style="min-height: 400px;")

            .col-12.col-lg-6.p-4.p-lg-5.d-flex.flex-column.justify-content-center

                a.text-decoration-none.text-muted.small.text-uppercase.fw-semibold.mb-3(href="/encuentros") Volver a los encuentros

                h1.display-6.fw-bold.mb-2.text-dark #{encuentro.ciudad}

                hr.border-secondary.opacity-25.mb-4

                h6.text-muted.text-uppercase.fw-bold.small Detalles del encuentro
                p.text-secondary.mb-4.lh-lg #{encuentro.actividades}

                div.mb-4
                    if apuntado
                        button.btn.btn-lg.btn-secondary.w-100(disabled style="border-radius: 0.5rem;")
                            i.fas.fa-check-circle.me-2
                            | Ya estás apuntado

                    else if encuentro.plazas_ocupadas >= encuentro.plazas_totales
                        button.btn.btn-lg.btn-danger.w-100(disabled style="border-radius: 0.5rem;")
                            i.fas.fa-times-circle.me-2
                            | Entradas Agotadas

                    else
                        form(action=`/encuentros/${encuentro.id}` method="POST" id="formReserva")
                            div.d-flex.flex-wrap.align-items-end.gap-3
                                div
                                    label.form-label.small.text-muted.fw-bold(for="cantidad") Cantidad
                                    input.form-control.form-control-lg.text-center(type="number" name="cantidad" id="cantidad" value="1" min="1" max="10" style="width: 90px; border-radius: 0.5rem;")

                                button.btn.btn-lg.text-white.flex-grow-1(type="submit" style="background-color: #1a8f79; border-radius: 0.5rem;")
                                    i.fas.fa-ticket-alt.me-2
                                    | Apuntarme al Evento

                h6.text-muted.text-uppercase.fw-bold.small.mt-3 Ubicación
                #map.rounded-4.shadow-sm.border.border-light.w-100(style="height: 250px; z-index: 1;" data-lat=encuentro.latitud data-lng=encuentro.longitud)

                script.
                    document.addEventListener('DOMContentLoaded', () => {
                        const mapaContenedor = document.getElementById('map');

                        if (mapaContenedor && mapaContenedor.dataset.lat && mapaContenedor.dataset.lng) {

                            const lat = parseFloat(mapaContenedor.dataset.lat);
                            const lng = parseFloat(mapaContenedor.dataset.lng);

                            const map = L.map('map').setView([lat, lng], 15);

                            L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                                maxZoom: 19,
                                attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
                            }).addTo(map);

                            L.marker([lat, lng]).addTo(map)
                                .bindPopup("<div class='text-center'><b>¡Aquí nos vemos!</b><br>Ubicación del encuentro.</div>")
                                .openPopup();
                        }
                    });

    include ./fijo/footer