.row.experiencias.texto
    each experiencia in experiencias
        .col-md-6.col-lg-4.mb-5
            .card.shadow-lg.col-md-12.bg-white.border-0.rounded-4
                .card-body
                    .blockquote
                        p.text-center
                            | "#{experiencia.situaciones}"
                    .blockquote-footer.text-right
                        | #{experiencia.nombre}

