extends ./index

block contenido
    include ./header
    .container-form
        .row.justify-content-center.mb-5
            .card.shadow-lg.bg-white.border-0.rounded-4.p-4
                .col-md-12
                    .welcome-back
                    form.formulario(action=`/administrador/editarProducto/${producto.id}` method="POST" enctype="multipart/form-data")
                        h2 Editar producto
                        input(type="text" name="Nombre" value=producto.nombre placeholder="Nombre" required)
                        input(type="number" step="0.01" name="Precio" value=producto.precio  placeholder="Precio" required)
                        input(type="text" name="Descripcion" value=producto.descripcion  placeholder="Descripcion" required)
                        input(type="number" name="Stock" value=producto.stock  placeholder="Stock" required)
                        input(type="file" class="form-control-file" name="imagenProducto" required)
                        input(type="submit" value="Editar producto")

                        if errores
                            each error in errores
                                div.alert.alert-danger= error.mensaje

    include ./footer