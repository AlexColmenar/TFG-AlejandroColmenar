.container-form
    .row.justify-content-center.mb-5
        .card.shadow-lg.bg-white.border-0.rounded-4.p-4
            .col-md-12
                .welcome-back
                form.formulario(action="/productos" enctype="multipart/form-data" method="POST")
                    h2 Añadir producto
                    input(type="text" name="Nombre" placeholder="Nombre" required)
                    input(type="number" step="0.01" name="Precio" placeholder="Precio" required)
                    input(type="text" name="Descripcion" placeholder="Descripcion" required)
                    input(type="number" name="Stock" placeholder="Stock producto" required)
                    input(type="file" class="form-control-file" name="imagenProducto" required)
                    input(type="submit" value="Añadir producto")

                    if errores
                        each error in errores
                            div.alert.alert-danger= error.mensaje
